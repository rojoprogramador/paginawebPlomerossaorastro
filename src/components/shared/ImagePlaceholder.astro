---
// src/components/shared/ImagePlaceholder.astro
// Placeholder mientras subes tus fotos reales
// Para reemplazar: borra este componente y usa <img> o <Image> de Astro

interface Props {
  slot?: string;       // descripción de qué foto va aquí
  width?: string;
  height?: string;
  class?: string;
  aspectRatio?: string; // ej: "16/9", "4/3", "1/1"
}

const {
  slot: description = 'Foto pendiente',
  width,
  height,
  class: className = '',
  aspectRatio,
} = Astro.props;

const style = [
  width  ? `width:${width}` : '',
  height ? `height:${height}` : '',
  aspectRatio ? `aspect-ratio:${aspectRatio}` : '',
].filter(Boolean).join(';');
---

<!--
  ╔══════════════════════════════════════════════╗
  ║  FOTO PENDIENTE: {description}               ║
  ║  Reemplazar este componente por:             ║
  ║  <img src="/images/..." alt="..." />         ║
  ║  o                                           ║
  ║  <Image src={import('...')} alt="..." />     ║
  ╚══════════════════════════════════════════════╝
-->
<div
  class={`img-placeholder ${className}`}
  style={style}
  role="img"
  aria-label={description}
>
  <svg class="placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
    <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
  </svg>
  <span class="placeholder-label">{description}</span>
</div>

<style>
  .img-placeholder {
    width: 100%;
    background: linear-gradient(135deg, #e2edf7, #d0e8f4);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border: 2px dashed rgba(0, 180, 216, 0.3);
    min-height: 200px;
    position: relative;
    overflow: hidden;
  }

  .img-placeholder::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(45deg, transparent 30%, rgba(0,180,216,0.05) 50%, transparent 70%);
    animation: shimmer 2s ease-in-out infinite;
  }

  @keyframes shimmer {
    0%   { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }

  .placeholder-icon {
    width: 40px;
    height: 40px;
    color: rgba(0, 180, 216, 0.5);
    margin-bottom: 0.5rem;
  }

  .placeholder-label {
    font-size: 0.75rem;
    color: rgba(21, 101, 192, 0.6);
    text-align: center;
    padding: 0 1rem;
    font-weight: 500;
  }
</style>
