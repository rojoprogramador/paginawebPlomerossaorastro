---
// src/components/shared/ServiceHero.astro
// Hero oscuro reutilizable para todas las páginas de servicio
// Estilo: imagen de fondo con overlay oscuro + contenido encima

import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { SITE } from '../../lib/seo';

interface Props {
  title: string;           // HTML permitido para el título
  subtitle: string;
  badgeLabel: string;      // ej: "🚿 Servicio más solicitado"
  badgeColor?: 'orange' | 'brand' | 'green';
  badgeLabel2?: string;    // badge secundario opcional
  badgeColor2?: 'orange' | 'brand' | 'green';
  imageSrc: ImageMetadata; // imagen importada desde src/assets/
  imageAlt: string;
  whatsappText: string;    // mensaje predefinido para WA
  breadcrumbs: { label: string; href?: string }[];
  ctaLabel?: string;       // texto del botón Cotizar (opcional, default: "Cotizar →")
  hideCotizar?: boolean;   // ocultar el botón de cotizar
}

const {
  title,
  subtitle,
  badgeLabel,
  badgeColor = 'brand',
  badgeLabel2,
  badgeColor2 = 'orange',
  imageSrc,
  imageAlt,
  whatsappText,
  breadcrumbs,
  ctaLabel = 'Cotizar →',
  hideCotizar = false,
} = Astro.props;
---

<section class="svc-hero">
  <!-- Fondo imagen -->
  <div class="svc-hero-bg">
    <Image src={imageSrc} alt={imageAlt} class="svc-hero-img" loading="eager" widths={[768, 1280, 1920]} sizes="100vw" />
  </div>
  <div class="svc-hero-overlay" />

  <div class="container svc-hero-content">
    <!-- Breadcrumb -->
    <nav class="svc-breadcrumb" aria-label="Ruta">
      {breadcrumbs.map((b, i) => (
        <>
          {b.href
            ? <a href={b.href} class="svc-bc-link">{b.label}</a>
            : <span class="svc-bc-current">{b.label}</span>}
          {i < breadcrumbs.length - 1 && <span class="svc-bc-sep">›</span>}
        </>
      ))}
    </nav>

    <!-- Badges -->
    <div class="svc-badges">
      <span class={`badge badge-${badgeColor}`}>{badgeLabel}</span>
      {badgeLabel2 && <span class={`badge badge-${badgeColor2}`}>{badgeLabel2}</span>}
    </div>

    <!-- Título -->
    <h1 class="svc-title" set:html={title} />

    <!-- Subtítulo -->
    <p class="svc-subtitle">{subtitle}</p>

    <!-- CTAs -->
    <div class="svc-ctas">
      <a
        href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(whatsappText)}`}
        class="btn btn-whatsapp btn-lg svc-btn"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="white">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WhatsApp
      </a>
      <a href={`tel:${SITE.phone1}`} class="btn btn-lg svc-btn svc-btn-ghost">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56-.35-.12-.74-.03-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.12-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.01 21c.71 0 .99-.63.99-1.18v-3.45c0-.54-.45-.99-.99-.99z"/>
        </svg>
        {SITE.phone1}
      </a>
      {!hideCotizar && (
        <a href="/contacto" class="btn btn-primary btn-lg svc-btn svc-btn-cotizar">
          {ctaLabel}
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .svc-hero {
    position: relative;
    min-height: 72vh;
    display: flex;
    align-items: flex-end;
    padding-bottom: 3.5rem;
    padding-top: 68px; /* navbar */
    overflow: hidden;
  }

  .svc-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .svc-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .svc-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(11, 34, 64, 0.97) 0%,
      rgba(11, 34, 64, 0.75) 55%,
      rgba(11, 34, 64, 0.35) 100%
    );
    z-index: 1;
  }

  .svc-hero-content {
    position: relative;
    z-index: 2;
    max-width: 680px;
  }

  /* Breadcrumb */
  .svc-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
    font-size: 0.8125rem;
  }

  .svc-bc-link {
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    transition: color 0.2s;
  }
  .svc-bc-link:hover { color: var(--color-brand); }

  .svc-bc-sep { color: rgba(255,255,255,0.3); }

  .svc-bc-current {
    color: var(--color-brand);
    font-weight: 600;
  }

  /* Badges */
  .svc-badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  /* Título */
  .svc-title {
    font-size: clamp(2rem, 5.5vw, 3.25rem);
    font-weight: 800;
    color: white;
    line-height: 1.12;
    margin-bottom: 1rem;
  }

  /* Subtítulo */
  .svc-subtitle {
    font-size: 1.0625rem;
    color: rgba(255,255,255,0.82);
    line-height: 1.65;
    margin-bottom: 1.75rem;
    max-width: 560px;
  }

  /* CTAs */
  .svc-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .svc-btn-ghost {
    background: rgba(255,255,255,0.12);
    color: white;
    border: 2px solid rgba(255,255,255,0.3);
    backdrop-filter: blur(8px);
  }
  .svc-btn-ghost:hover {
    background: rgba(255,255,255,0.22);
    color: white;
  }

  /* ---- MOBILE ---- */
  @media (max-width: 640px) {
    .svc-hero {
      min-height: 100svh;   /* ocupa toda la pantalla */
      align-items: flex-end;
      padding-bottom: 2.5rem;
    }

    .svc-ctas {
      display: flex;
      flex-direction: column;
      gap: 0.625rem;
    }

    /* WhatsApp y Llamar, ancho completo */
    .svc-btn {
      width: 100%;
      justify-content: center;
    }

    /* Cotizar se oculta en mobile */
    .svc-btn-cotizar {
      display: none;
    }

    .svc-title {
      font-size: clamp(1.875rem, 7vw, 2.5rem);
    }
  }
</style>
