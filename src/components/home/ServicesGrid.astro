---
// src/components/home/ServicesGrid.astro
import { Image } from 'astro:assets';
import SectionTitle from '../shared/SectionTitle.astro';

// Importar imágenes estáticas para optimización automática de Astro
import imgDestape    from '../../assets/services/destape-canerias-sonda.jpg';
import imgFugas      from '../../assets/services/deteccion-fugas-equipo.jpg';
import imgGeofono    from '../../assets/services/geofono-inspeccion.jpg';
import imgTermica    from '../../assets/services/camara-termica-cali.jpg';
import imgEndosco    from '../../assets/services/camara-endoscopica.jpg';
import imgRemoda     from '../../assets/services/remodelacion-banos.jpg';
import imgTuberia    from '../../assets/services/instalacion-tuberia.jpg';

const services = [
  {
    icon: '🚿',
    title: 'Destape de Cañerías',
    description: 'Destapamos lavamanos, duchas, inodoros y redes internas sin dañar tu propiedad. Solución rápida y definitiva.',
    href: '/destape-de-canerias-cali',
    badge: 'Más solicitado',
    badgeColor: 'orange',
    imgSrc: imgDestape,
    imgAlt: 'Destape de cañerías en Cali — Plomeros SAOR',
  },
  {
    icon: '💧',
    title: 'Detección de Fugas',
    description: '¿Tu factura de agua subió sin razón? Encontramos fugas ocultas sin demoler. Diagnóstico con tecnología especializada.',
    href: '/deteccion-de-fugas-de-agua-como-saber-si-en-mi-casa-tengo-una-fuga-de-agua',
    badge: null,
    imgSrc: imgFugas,
    imgAlt: 'Detección de fugas de agua en Cali — Plomeros SAOR',
  },
  {
    icon: '🎯',
    title: 'Geófono',
    description: 'Tecnología acústica de precisión para localizar fugas dentro de tuberías empotradas. Sin romper paredes ni pisos.',
    href: '/servicio-geofono-cali',
    badge: '⭐ Especialidad',
    badgeColor: 'brand',
    imgSrc: imgGeofono,
    imgAlt: 'Servicio de geófono para detección de fugas en Cali',
  },
  {
    icon: '🌡️',
    title: 'Cámara Térmica',
    description: 'Termografía infrarroja para visualizar fugas de calor y humedad detrás de muros y bajo pisos. Resultado inmediato.',
    href: '/servicio-camara-termica-cali',
    badge: null,
    badgeColor: 'sky',
    imgSrc: imgTermica,
    imgAlt: 'Cámara térmica para detección de fugas en Cali',
    zoomSm: true,
  },
  {
    icon: '🔦',
    title: 'Cámara Endoscópica',
    description: 'Inspección visual interior de tuberías con videocámara flexible. Identificamos obstrucciones, raíces y daños sin demoler.',
    href: '/camara-endoscopica-inspeccion-tuberias-cali',
    badge: '🔦 Tecnología',
    badgeColor: 'brand',
    imgSrc: imgEndosco,
    imgAlt: 'Cámara endoscópica inspección de tuberías en Cali',
  },
  {
    icon: '🛁',
    title: 'Remodelación de Baños',
    description: 'Transformamos tu baño completo: cambio de tubería, enchape, sanitarios e instalaciones eléctricas. Llave en mano.',
    href: '/remodelacion-de-banos-cali',
    badge: null,
    badgeColor: 'sky',
    imgSrc: imgRemoda,
    imgAlt: 'Remodelación de baños en Cali — Plomeros SAOR',
  },
  {
    icon: '🔧',
    title: 'Instalación de Tubería',
    description: 'Instalación de tuberías nuevas, cambio de redes antiguas y conexiones para gasodomésticos. Materiales garantizados.',
    href: '/instalacion-tuberia-cali',
    badge: null,
    imgSrc: imgTuberia,
    imgAlt: 'Instalación de tubería en Cali — Plomeros SAOR',
  },
];
---

<section class="section" id="servicios">
  <div class="container">
    <SectionTitle
      badge="Nuestros servicios"
      title="¿Qué necesitas <span class='text-gradient-brand'>solucionar</span> hoy?"
      subtitle="Contamos con el equipo y la tecnología para resolver cualquier problema de plomería en Cali y alrededores."
      center={true}
    />

    <div class="services-grid">
      {services.map((service, i) => (
        <article class="service-card" style={`animation-delay:${i * 0.08}s`}>
          <!-- Imagen optimizada con <Image> de Astro -->
          <div class="service-img-wrap">
            <Image
              src={service.imgSrc}
              alt={service.imgAlt}
              width={480}
              height={220}
              loading="lazy"
              quality={35}
              class={`service-img${service.zoomSm ? ' img-zoom-sm' : ''}`}
            />
            {service.badge && (
              <span class={`service-badge badge-${service.badgeColor ?? 'brand'}`}>
                {service.badge}
              </span>
            )}
          </div>

          <div class="service-body">
            <div class="service-icon">{service.icon}</div>
            <h3 class="service-title">{service.title}</h3>
            <p class="service-desc">{service.description}</p>
            <a href={service.href} class="service-link" aria-label={`Ver servicio: ${service.title}`}>
              Ver servicio
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA al hub -->
    <div style="text-align:center; margin-top:2.5rem;">
      <a href="/plomeros-en-cali" class="btn btn-navy btn-lg">
        Ver todos los servicios en Cali →
      </a>
    </div>
  </div>
</section>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    background: white;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid rgba(0, 180, 216, 0.07);
    animation: fadeInUp 0.5s ease both;
  }

  .service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 16px 48px rgba(11, 34, 64, 0.15);
  }

  /* Imagen */
  .service-img-wrap {
    position: relative;
    overflow: hidden;
    height: 220px;
  }

  .service-img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    object-position: center 20%;
    transition: transform 0.4s ease;
    display: block;
  }

  /* Zoom extra para la cámara térmica */
  .img-zoom-sm {
    transform: scale(1.15);
    object-position: center 40%;
  }

  .service-card:hover .service-img {
    transform: scale(1.08);
  }

  .service-card:hover .img-zoom-sm {
    transform: scale(1.22);
  }

  /* Badge sobre imagen */
  .service-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    padding: 0.25rem 0.625rem;
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 700;
    backdrop-filter: blur(4px);
  }

  .badge-orange {
    background: rgba(249, 115, 22, 0.9);
    color: white;
  }
  .badge-brand {
    background: rgba(0, 180, 216, 0.9);
    color: white;
  }
  .badge-sky {
    background: rgba(79, 195, 247, 0.9);
    color: var(--color-navy);
  }

  /* Body */
  .service-body {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .service-icon {
    font-size: 1.75rem;
    margin-bottom: 0.5rem;
    line-height: 1;
  }

  .service-title {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 0.5rem;
  }

  .service-desc {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-mid-blue);
    text-decoration: none;
    transition: gap 0.2s ease, color 0.2s ease;
  }

  .service-link:hover {
    gap: 0.625rem;
    color: var(--color-navy);
  }

  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .services-grid { grid-template-columns: 1fr; }
  }
</style>
