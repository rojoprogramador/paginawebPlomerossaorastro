---
// src/components/home/SymptomsMatrix.astro
import { SITE } from '../../lib/seo';

const waHref = `https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent('Hola, tengo un problema de plomería y necesito orientación')}`;

const symptoms = [
  {
    icon: '🚰',
    title: 'Llave o grifo goteando',
    detail: 'Goteo constante aunque la llave esté cerrada.',
    urgency: 'Bajo',
    action: 'Cierra la llave de paso individual. Programa la reparación antes de que aumente la factura.',
    color: 'green',
  },
  {
    icon: '🚿',
    title: 'Desagüe lento o tapado',
    detail: 'Lavaplatos, ducha o lavamanos que drena muy despacio.',
    urgency: 'Medio',
    action: 'Evita productos químicos que dañan el tubo. Llama para un destape profesional.',
    color: 'yellow',
  },
  {
    icon: '🚽',
    title: 'Sanitario que bota agua',
    detail: 'El tanque recarga continuamente o hay agua en la base.',
    urgency: 'Medio',
    action: 'Cierra la llave de paso del sanitario y llama. Puede estar perdiendo cientos de litros por día.',
    color: 'yellow',
  },
  {
    icon: '💧',
    title: 'Mancha de humedad sin causa',
    detail: 'Pared, techo o piso mojado sin que haya habido lluvia ni derrame.',
    urgency: 'Medio',
    action: 'Puede ser fuga interna. No la ignores: el daño estructural crece cada día.',
    color: 'yellow',
  },
  {
    icon: '📊',
    title: 'Factura de agua disparada',
    detail: 'El cobro subió más del 20% sin cambiar tus hábitos de consumo.',
    urgency: 'Medio',
    action: 'Cierra todas las llaves y revisa si el medidor sigue girando. Si gira, hay fuga activa.',
    color: 'yellow',
  },
  {
    icon: '⬇️',
    title: 'Presión de agua muy baja',
    detail: 'El chorro de ducha o llaves sale muy débil en toda la casa.',
    urgency: 'Medio',
    action: 'Puede ser fuga interna que roba caudal. Requiere diagnóstico con geófono.',
    color: 'yellow',
  },
  {
    icon: '💦',
    title: 'Pérdida de agua visible',
    detail: 'Agua saliendo de pared, piso o tubo roto de forma continua.',
    urgency: 'Alto',
    action: 'Cierra la llave principal de paso YA y llama de inmediato.',
    color: 'red',
  },
  {
    icon: '🌊',
    title: 'Cañería tapada con desbordamiento',
    detail: 'Aguas negras suben por el desagüe o hay inundación en baño/cocina.',
    urgency: 'Urgente',
    action: 'Emergencia sanitaria. Cierra el suministro general y llama ahora.',
    color: 'red',
  },
];

const colorMap = {
  green:  { badge: '#15803d', bg: 'rgba(21,128,61,.08)', border: 'rgba(21,128,61,.2)'  },
  yellow: { badge: '#b45309', bg: 'rgba(180,83,9,.07)',  border: 'rgba(180,83,9,.2)'   },
  red:    { badge: '#b91c1c', bg: 'rgba(185,28,28,.07)', border: 'rgba(185,28,28,.2)'  },
};
---

<section class="section" id="que-problema-tienes">
  <div class="container">

    <div class="matrix-header">
      <span class="matrix-badge">Diagnóstico rápido</span>
      <h2 class="matrix-title">¿Cuál es tu problema de plomería?</h2>
      <p class="matrix-sub">
        Identifica tu situación y sabe qué tan urgente es actuar.
        Ante cualquier duda, escríbenos y te orientamos gratis.
      </p>
    </div>

    <div class="matrix-grid">
      {symptoms.map(s => {
        const c = colorMap[s.color as keyof typeof colorMap];
        return (
          <div
            class="symptom-card"
            style={`background:${c.bg};border-color:${c.border};`}
          >
            <div class="symptom-top">
              <span class="symptom-icon" aria-hidden="true">{s.icon}</span>
              <span class="urgency-badge" style={`background:${c.badge};`}>
                {s.urgency}
              </span>
            </div>
            <h3 class="symptom-title">{s.title}</h3>
            <p class="symptom-detail">{s.detail}</p>
            <div class="symptom-action">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
              {s.action}
            </div>
          </div>
        );
      })}
    </div>

    <div class="matrix-cta">
      <p class="matrix-cta-text">
        ¿No sabes exactamente qué tienes? Cuéntanos y te ayudamos a identificarlo.
      </p>
      <div class="matrix-cta-btns">
        <a
          href={waHref}
          class="btn btn-whatsapp"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Consultar por WhatsApp
        </a>
        <a href={`tel:${SITE.phone1}`} class="btn btn-secondary">
          Llamar ahora
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  .matrix-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .matrix-badge {
    display: inline-block;
    background: rgba(0,180,216,.12);
    color: var(--color-navy);
    border: 1px solid rgba(0,180,216,.3);
    padding: 0.25rem 0.875rem;
    border-radius: 99px;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    margin-bottom: 0.75rem;
  }

  .matrix-title {
    font-size: clamp(1.5rem, 3vw, 2.125rem);
    font-weight: 800;
    color: var(--color-navy);
    margin-bottom: 0.5rem;
  }

  .matrix-sub {
    color: var(--color-muted);
    font-size: 1rem;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* Grid */
  .matrix-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .symptom-card {
    border: 1px solid;
    border-radius: var(--radius-lg);
    padding: 1.125rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .symptom-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .symptom-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .symptom-icon { font-size: 1.5rem; line-height: 1; }

  .urgency-badge {
    color: white;
    font-size: 0.6875rem;
    font-weight: 700;
    padding: 0.2rem 0.5rem;
    border-radius: 99px;
    white-space: nowrap;
    letter-spacing: 0.04em;
  }

  .symptom-title {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-navy);
    line-height: 1.3;
  }

  .symptom-detail {
    font-size: 0.8125rem;
    color: var(--color-muted);
    line-height: 1.55;
    flex: 1;
  }

  .symptom-action {
    display: flex;
    align-items: flex-start;
    gap: 0.375rem;
    font-size: 0.8rem;
    color: var(--color-navy);
    font-weight: 600;
    line-height: 1.45;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(11,34,64,.07);
  }

  .symptom-action svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-brand);
  }

  /* CTA inferior */
  .matrix-cta {
    background: var(--color-navy);
    border-radius: var(--radius-xl);
    padding: 2rem 2.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .matrix-cta-text {
    color: rgba(255,255,255,.85);
    font-size: 1rem;
    font-weight: 500;
    max-width: 480px;
    line-height: 1.6;
  }

  .matrix-cta-btns {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .matrix-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .matrix-grid { grid-template-columns: 1fr; }
    .matrix-cta {
      flex-direction: column;
      align-items: flex-start;
      padding: 1.5rem;
    }
    .matrix-cta-btns { width: 100%; }
    .matrix-cta-btns .btn { flex: 1; justify-content: center; }
  }
</style>
