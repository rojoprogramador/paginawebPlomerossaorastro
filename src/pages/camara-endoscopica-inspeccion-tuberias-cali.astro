---
// src/pages/camara-endoscopica-inspeccion-tuberias-cali.astro

import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/shared/Breadcrumb.astro';
import CTAEmergency from '../components/home/CTAEmergency.astro';
import { Image } from 'astro:assets';
import { SITE, buildTitle } from '../lib/seo';
import imgEndoscopica from '../assets/services/camara-endoscopica.jpg';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Qué es una cámara endoscópica en plomería?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Es una videocámara flexible que se introduce por el interior de las tuberías para inspeccionar su estado internamente, detectar obstrucciones, raíces, fisuras o deformaciones sin necesidad de excavar o demoler.',
      },
    },
    {
      '@type': 'Question',
      name: '¿En qué casos se usa la cámara endoscópica?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Se usa para diagnosticar tapones crónicos, inspeccionar tuberías antes de una remodelación, verificar el estado de la red de desagüe en compra de inmuebles, o localizar objetos caídos dentro de la tubería.',
      },
    },
    {
      '@type': 'Question',
      name: '¿La cámara endoscópica daña la tubería?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. La cámara es flexible y no invasiva. Se introduce por los registros o accesos existentes sin necesidad de romper ninguna superficie.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cuánto demora la inspección con cámara endoscópica?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Una inspección típica de red de desagüe domiciliaria tarda entre 30 y 60 minutos. Redes más largas o complejas pueden tomar hasta 2 horas.',
      },
    },
  ],
};
---

<Layout
  title={buildTitle('Cámara Endoscópica para Inspección de Tuberías en Cali · Plomeros SAOR')}
  description="Inspección de tuberías con cámara endoscópica en Cali. Detectamos obstrucciones, raíces y daños internos sin demoler. Diagnóstico visual preciso. ☎ 318 592 2585."
  canonical="/camara-endoscopica-inspeccion-tuberias-cali"
  schema={faqSchema}
>
  <div style="padding-top:68px;" />

  <!-- Hero -->
  <section style="background:linear-gradient(135deg,var(--color-navy),#0f3460);padding:4rem 0 5rem;">
    <div class="container">
      <Breadcrumb items={[
        {label:'Inicio',href:'/'},
        {label:'Servicios',href:'/plomeros-en-cali'},
        {label:'Cámara endoscópica'}
      ]} />
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;margin-top:1.5rem;">
        <div>
          <span class="badge badge-brand" style="margin-bottom:1rem;display:inline-block;">🔦 Inspección sin demoler</span>
          <h1 style="font-size:clamp(2rem,4vw,2.75rem);font-weight:800;color:white;line-height:1.15;margin-bottom:0.875rem;">
            Cámara Endoscópica para<br>
            <span style="color:var(--color-brand);">Inspección de Tuberías</span> en Cali
          </h1>
          <p style="font-size:1.0625rem;color:rgba(255,255,255,0.8);line-height:1.65;margin-bottom:1.75rem;">
            Introducimos una videocámara flexible por el interior de tu red de tuberías.
            Vemos exactamente qué hay dentro: taponamiento, raíces, fisuras o deformaciones.
            Sin excavar. Sin demoler.
          </p>
          <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
            <a href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent('Necesito inspección con cámara endoscópica en Cali')}`}
               class="btn btn-whatsapp btn-lg" target="_blank" rel="noopener">WhatsApp</a>
            <a href={`tel:${SITE.phone1}`} class="btn btn-lg"
               style="background:rgba(255,255,255,0.15);color:white;border:2px solid rgba(255,255,255,0.3);">
              📞 {SITE.phone1}
            </a>
          </div>
        </div>
        <Image
          src={imgEndoscopica}
          alt="Inspección visual de tuberías con cámara endoscópica en Cali — Plomeros SAOR"
          style="width:100%; height:360px; object-fit:cover; border-radius:var(--radius-lg); box-shadow:var(--shadow-md);"
          loading="eager"
          widths={[480, 800]}
          sizes="(max-width:768px) 100vw, 50vw"
        />
      </div>
    </div>
  </section>

  <!-- Trust badges -->
  <section style="background:white;padding:2rem 0;border-bottom:1px solid rgba(0,180,216,0.1);">
    <div class="container">
      <div style="display:flex;justify-content:center;gap:3rem;flex-wrap:wrap;">
        {[
          {icon:'🎥',text:'Video en tiempo real'},
          {icon:'📏',text:'Localización exacta'},
          {icon:'🚫',text:'Sin demolición'},
          {icon:'📋',text:'Informe con imágenes'},
        ].map(i => (
          <div style="display:flex;align-items:center;gap:0.5rem;font-weight:600;color:var(--color-navy);font-size:0.9375rem;">
            <span style="font-size:1.25rem;">{i.icon}</span>{i.text}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Cómo funciona -->
  <section class="section">
    <div class="container">
      <h2 style="font-size:clamp(1.5rem,3.5vw,2rem);font-weight:800;color:var(--color-navy);text-align:center;margin-bottom:0.5rem;">
        ¿Cómo funciona la cámara endoscópica?
      </h2>
      <p style="text-align:center;color:var(--color-muted);max-width:560px;margin:0 auto 2.5rem;font-size:0.9375rem;">
        Un proceso no invasivo de inspección visual que te da la certeza de qué está pasando dentro de tus tuberías.
      </p>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1.25rem;">
        {[
          {n:'01',icon:'🔍',title:'Diagnóstico inicial',desc:'Evaluamos el síntoma: tapón crónico, humedad, ruidos, etc.'},
          {n:'02',icon:'🔌',title:'Inserción de cámara',desc:'Introducimos el cable con cámara por el acceso de registro existente.'},
          {n:'03',icon:'📺',title:'Inspección en vivo',desc:'La señal llega en tiempo real a nuestro monitor. Grabamos todo.'},
          {n:'04',icon:'📋',title:'Informe con fotos',desc:'Te entregamos el diagnóstico con imágenes del problema encontrado.'},
        ].map(s => (
          <div class="card" style="padding:1.5rem;text-align:center;">
            <div style="font-family:'Sora',sans-serif;font-size:0.75rem;font-weight:800;color:var(--color-brand);letter-spacing:0.05em;margin-bottom:0.5rem;">{s.n}</div>
            <div style="font-size:2rem;margin-bottom:0.625rem;">{s.icon}</div>
            <h3 style="font-size:0.9375rem;font-weight:700;color:var(--color-navy);margin-bottom:0.375rem;">{s.title}</h3>
            <p style="font-size:0.8125rem;color:var(--color-muted);line-height:1.55;">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Casos de uso -->
  <section style="background:var(--color-bg-light);padding:4rem 0;">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start;">
        <div>
          <h2 style="font-size:clamp(1.5rem,3vw,1.875rem);font-weight:800;color:var(--color-navy);margin-bottom:1rem;">
            ¿Cuándo necesitas una inspección con cámara?
          </h2>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:0.875rem;">
            {[
              'Tapón crónico que vuelve una y otra vez',
              'Revisión de la red antes de comprar un inmueble',
              'Inspección antes de una remodelación de baño o cocina',
              'Olores persistentes sin causa visible',
              'Objetos caídos accidentalmente (ropa, juguetes)',
              'Raíces de árboles que pueden estar entrando a la red',
              'Verificación post-reparación para confirmar resultado',
              'Inspección de red en edificios o conjuntos residenciales',
            ].map(item => (
              <li style="display:flex;gap:0.75rem;align-items:flex-start;">
                <span style="color:var(--color-brand);font-size:1rem;margin-top:0.1rem;flex-shrink:0;">✓</span>
                <span style="font-size:0.9375rem;color:var(--color-text);line-height:1.55;">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h2 style="font-size:clamp(1.5rem,3vw,1.875rem);font-weight:800;color:var(--color-navy);margin-bottom:1rem;">
            ¿Qué detecta la cámara?
          </h2>
          <div style="display:grid;gap:1rem;">
            {[
              {icon:'🌿',title:'Raíces de árboles',desc:'Penetran por uniones de la tubería y crecen bloqueando el paso.'},
              {icon:'🧱',title:'Incrustaciones y depósitos',desc:'Cal, grasa y sedimentos que reducen el diámetro interno.'},
              {icon:'💥',title:'Fisuras y fracturas',desc:'Grietas que pueden colapsar la tubería o generar filtraciones.'},
              {icon:'↔️',title:'Desplazamientos de junta',desc:'Uniones separadas o deformadas que retienen sólidos.'},
              {icon:'🧦',title:'Objetos extraños',desc:'Ropa, juguetes, tapas y otros objetos atrapados.'},
            ].map(d => (
              <div style="display:flex;gap:0.875rem;align-items:flex-start;background:white;border-radius:var(--radius-md);padding:1rem;box-shadow:var(--shadow-sm);">
                <span style="font-size:1.5rem;flex-shrink:0;">{d.icon}</span>
                <div>
                  <div style="font-weight:700;color:var(--color-navy);font-size:0.9rem;margin-bottom:0.125rem;">{d.title}</div>
                  <div style="font-size:0.8125rem;color:var(--color-muted);line-height:1.5;">{d.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width:720px;">
      <h2 style="font-size:clamp(1.5rem,3vw,2rem);font-weight:800;color:var(--color-navy);text-align:center;margin-bottom:2rem;">
        Preguntas frecuentes
      </h2>
      <div style="display:flex;flex-direction:column;gap:1rem;">
        {faqSchema.mainEntity.map(faq => (
          <div style="background:white;border-radius:var(--radius-md);padding:1.25rem 1.5rem;box-shadow:var(--shadow-sm);border-left:3px solid var(--color-brand);">
            <h3 style="font-weight:700;color:var(--color-navy);font-size:0.9375rem;margin-bottom:0.375rem;">{faq.name}</h3>
            <p style="font-size:0.875rem;color:var(--color-muted);line-height:1.6;">{faq.acceptedAnswer.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTAEmergency />
</Layout>
