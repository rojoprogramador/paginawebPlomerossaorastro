---
// src/pages/about-plomeros-cali.astro

import Layout from '../layouts/Layout.astro';
import CTAEmergency from '../components/home/CTAEmergency.astro';
import Testimonials from '../components/home/Testimonials';
import { Image } from 'astro:assets';
import { SITE, buildTitle } from '../lib/seo';
import imgEquipo from '../assets/team/carro-empresa-saor.png';
---

<Layout
  title={buildTitle('Sobre Nosotros — Plomeros SAOR en Cali')}
  description="Plomeros SAOR: más de 7 años de experiencia en servicios de plomería en Cali. Conoce nuestro equipo, valores y tecnología. ☎ 318 592 2585."
  canonical="/about-plomeros-cali"
>
  <div style="padding-top:68px;" />

  <section style="background:var(--color-bg-light);padding:4rem 0;">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;">
        <div>
          <span class="badge badge-brand" style="margin-bottom:1rem;display:inline-block;">Nuestra historia</span>
          <h1 style="font-size:clamp(2rem,4vw,2.75rem);font-weight:800;color:var(--color-navy);line-height:1.15;margin-bottom:1rem;">
            Plomeros SAOR —<br><span class="text-gradient-brand">Servicios Locativos de Calidad</span>
          </h1>
          <p style="font-size:1.0625rem;color:var(--color-muted);line-height:1.7;margin-bottom:1rem;">
            Somos una empresa de plomería con más de 6 años de experiencia en Cali, Valle del Cauca.
            Nos especializamos en detección de fugas sin demoler, usando tecnología de geófono y
            cámara térmica que nos diferencia del plomero tradicional.
          </p>
          <p style="font-size:1rem;color:var(--color-muted);line-height:1.7;margin-bottom:1.5rem;">
            Nuestro equipo está capacitado en las más modernas técnicas de diagnóstico y reparación.
            Atendemos casas, apartamentos, oficinas y proyectos comerciales en Cali, Jamundí,
            Palmira y Yumbo.
          </p>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
            {[
              {v:'6+',l:'Años de experiencia'},
              {v:'200+',l:'Clientes satisfechos'},
              {v:'4.9★',l:'Calificación promedio'},
              {v:'24/7',l:'Disponibilidad'},
            ].map(s => (
              <div style="background:white;border-radius:var(--radius-md);padding:1.25rem;border:1px solid rgba(0,180,216,0.1);text-align:center;">
                <div style="font-family:'Sora',sans-serif;font-size:1.75rem;font-weight:800;color:var(--color-brand);">{s.v}</div>
                <div style="font-size:0.8125rem;color:var(--color-muted);margin-top:0.125rem;">{s.l}</div>
              </div>
            ))}
          </div>
        </div>
        <Image
          src={imgEquipo}
          alt="Equipo Plomeros SAOR — Técnicos profesionales en Cali"
          class="about-team-img"
          style="width:100%; height:480px; object-fit:cover; border-radius:var(--radius-lg); box-shadow:var(--shadow-lg);"
          loading="eager"
          widths={[480, 800]}
          sizes="(max-width:768px) 100vw, 50vw"
        />
      </div>
    </div>
  </section>

  <!-- Valores -->
  <section class="section">
    <div class="container">
      <h2 style="font-size:clamp(1.5rem,3.5vw,2rem);font-weight:800;color:var(--color-navy);text-align:center;margin-bottom:2.5rem;">
        ¿Por qué confiar en Plomeros SAOR?
      </h2>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;">
        {[
          {icon:'🎯',title:'Diagnóstico preciso',desc:'Geófono y cámara térmica para localizar el problema sin adivinar.'},
          {icon:'⚡',title:'Respuesta rápida',desc:'Emergencias atendidas en menos de 1 hora en Cali.'},
          {icon:'✅',title:'Garantía real',desc:'Respaldamos cada trabajo. Si falla, regresamos.'},
          {icon:'💰',title:'Precio justo',desc:'Presupuesto antes de empezar, sin sorpresas.'},
          {icon:'📋',title:'Con factura',desc:'Emitimos factura electrónica en cada servicio.'},
          {icon:'👷',title:'Equipo certificado',desc:'Técnicos capacitados y con experiencia comprobada.'},
        ].map(v => (
          <div class="card" style="padding:1.75rem;text-align:center;">
            <div style="font-size:2rem;margin-bottom:0.75rem;">{v.icon}</div>
            <h3 style="font-weight:700;color:var(--color-navy);margin-bottom:0.375rem;">{v.title}</h3>
            <p style="font-size:0.875rem;color:var(--color-muted);line-height:1.6;">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Testimonials client:visible />
  <CTAEmergency />
</Layout>
