---
// src/pages/instalacion-tuberia-cali.astro

import Layout from '../layouts/Layout.astro';
import ServiceHero from '../components/shared/ServiceHero.astro';
import CTAEmergency from '../components/home/CTAEmergency.astro';
import { SITE, buildTitle } from '../lib/seo';
import imgHero from '../assets/services/instalacion-tuberia.jpg';
---

<Layout
  title={buildTitle('Instalación de Tubería en Cali — Plomeros SAOR')}
  description="Instalación y cambio de tuberías en Cali. PVC, cobre y polietileno. Conexiones para gasodomésticos, redes nuevas y reposición de redes antiguas. ☎ 318 592 2585."
  canonical="/instalacion-tuberia-cali"
>
  <ServiceHero
    title="Instalación de Tubería en <span class='text-gradient-brand'>Cali</span>"
    subtitle="Instalamos tuberías nuevas, cambiamos redes antiguas y hacemos conexiones para gasodomésticos. Materiales certificados y garantía en todos los trabajos."
    badgeLabel="🔧 Instalaciones garantizadas"
    badgeColor="brand"
    imageSrc={imgHero}
    imageAlt="Instalación de tubería profesional en Cali — Plomeros SAOR"
    whatsappText="Hola, necesito cotizar instalación de tubería en Cali"
    ctaLabel="Solicitar cotización →"
    breadcrumbs={[
      { label: 'Inicio', href: '/' },
      { label: 'Servicios', href: '/plomeros-en-cali' },
      { label: 'Instalación de tubería' },
    ]}
  />

  <section class="section">
    <div class="container">
      <div class="tuberia-grid">
        {[
          {icon:'🔵', title:'Tubería PVC', desc:'Red de agua fría, desagüe y ventilación. Material duradero y económico.'},
          {icon:'🟡', title:'Tubería de cobre', desc:'Instalaciones de agua caliente y sanitaria de alta calidad.'},
          {icon:'⚫', title:'Polietileno', desc:'Tuberías enterradas y redes principales de agua potable.'},
          {icon:'🔥', title:'Conexión a gas', desc:'Instalaciones certificadas para gasodomésticos y calentadores.'},
          {icon:'🏗️', title:'Proyectos nuevos', desc:'Instalación completa en obras nuevas: casas y apartamentos.'},
          {icon:'🔄', title:'Cambio de red', desc:'Reposición de tuberías antiguas de hierro galvanizado o asbesto cemento.'},
        ].map(i => (
          <div class="card" style="padding:1.5rem;">
            <div style="font-size:1.75rem;margin-bottom:0.5rem;">{i.icon}</div>
            <h3 style="font-weight:700;color:var(--color-navy);font-size:0.9375rem;margin-bottom:0.25rem;">{i.title}</h3>
            <p style="font-size:0.8125rem;color:var(--color-muted);line-height:1.5;">{i.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTAEmergency />
</Layout>

<style>
  .tuberia-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.25rem;
  }
  @media (max-width: 480px) {
    .tuberia-grid { grid-template-columns: 1fr; }
  }
</style>
