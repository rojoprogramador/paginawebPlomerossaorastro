---
// src/pages/contacto.astro

import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/contact/ContactForm';
import Breadcrumb from '../components/shared/Breadcrumb.astro';
import { SITE, buildTitle } from '../lib/seo';
---

<Layout
  title={buildTitle('Contacto — Solicita tu Servicio de Plomería en Cali')}
  description="Contáctanos para solicitar servicio de plomería en Cali. Respuesta en menos de 1 hora. Teléfono: 318 592 2585. Formulario de contacto disponible 24 horas."
  canonical="/contacto"
>
  <!-- Espaciado navbar -->
  <div style="padding-top: 68px;" />

  <div class="contact-page">
    <div class="container">
      <Breadcrumb items={[
        { label: 'Inicio', href: '/' },
        { label: 'Contacto' },
      ]} />

      <div class="contact-grid">
        <!-- Formulario -->
        <div class="contact-form-col">
          <div class="section-tag">Cuéntanos tu problema</div>
          <h1 class="contact-title">
            Solicita tu <span class="text-gradient-brand">servicio</span> hoy
          </h1>
          <p class="contact-subtitle">
            Completa el formulario y te contactamos en menos de 1 hora. 
            Sin compromiso, sin costo de visita para diagnóstico.
          </p>

          <div class="form-card">
            <ContactForm client:load />
          </div>
        </div>

        <!-- Información de contacto -->
        <aside class="contact-info-col">
          <!-- Teléfonos -->
          <div class="info-card">
            <h2 class="info-card-title">📞 Llámanos ahora</h2>
            <div class="phone-list">
              <a href={`tel:${SITE.phone1}`} class="phone-item">
                <div class="phone-icon">📱</div>
                <div>
                  <div class="phone-number">{SITE.phone1}</div>
                  <div class="phone-label">Principal · 24 horas</div>
                </div>
              </a>
              <a href={`tel:${SITE.phone2}`} class="phone-item">
                <div class="phone-icon">📱</div>
                <div>
                  <div class="phone-number">{SITE.phone2}</div>
                  <div class="phone-label">Alternativo</div>
                </div>
              </a>
            </div>
          </div>

          <!-- WhatsApp -->
          <a
            href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent('Hola, necesito un servicio de plomería en Cali')}`}
            class="whatsapp-card"
            target="_blank"
            rel="noopener noreferrer"
          >
            <div class="whatsapp-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="white">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <div class="whatsapp-label">WhatsApp</div>
              <div class="whatsapp-number">{SITE.whatsapp.replace('57', '+57 ')}</div>
              <div class="whatsapp-status">
                <span class="online-dot" /> En línea ahora
              </div>
            </div>
          </a>

          <!-- Info adicional -->
          <div class="info-card">
            <h2 class="info-card-title">ℹ️ Información</h2>
            <div class="info-list">
              <div class="info-item">
                <span class="info-icon">⏰</span>
                <div>
                  <strong>Horario</strong>
                  <p>24 horas · 7 días a la semana</p>
                </div>
              </div>
              <div class="info-item">
                <span class="info-icon">📍</span>
                <div>
                  <strong>Cobertura</strong>
                  <p>Cali, Jamundí, Palmira, Yumbo</p>
                </div>
              </div>
              <div class="info-item">
                <span class="info-icon">⚡</span>
                <div>
                  <strong>Respuesta</strong>
                  <p>Menos de 1 hora en emergencias</p>
                </div>
              </div>
              <div class="info-item">
                <span class="info-icon">💰</span>
                <div>
                  <strong>Presupuesto</strong>
                  <p>Gratis y sin compromiso</p>
                </div>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </div>
</Layout>

<style>
  .contact-page {
    padding: 2rem 0 5rem;
    background: var(--color-bg-light);
    min-height: 100vh;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 3rem;
    margin-top: 1.5rem;
    align-items: start;
  }

  /* Formulario */
  .section-tag {
    display: inline-block;
    background: rgba(0, 180, 216, 0.1);
    border: 1px solid rgba(0, 180, 216, 0.3);
    color: var(--color-brand);
    padding: 0.25rem 0.875rem;
    border-radius: 99px;
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }

  .contact-title {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 800;
    color: var(--color-navy);
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .contact-subtitle {
    font-size: 1rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin-bottom: 1.75rem;
  }

  .form-card {
    background: white;
    border-radius: var(--radius-xl);
    padding: 2.5rem;
    box-shadow: var(--shadow-lg);
    border: 1px solid rgba(0, 180, 216, 0.08);
  }

  /* Info lateral */
  .contact-info-col {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 88px;
  }

  .info-card {
    background: white;
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: var(--shadow-md);
    border: 1px solid rgba(0, 180, 216, 0.08);
  }

  .info-card-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 1rem;
  }

  /* Teléfonos */
  .phone-list { display: flex; flex-direction: column; gap: 0.75rem; }

  .phone-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
    padding: 0.75rem;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(0, 180, 216, 0.1);
    transition: all 0.2s ease;
    background: var(--color-bg-light);
  }

  .phone-item:hover {
    border-color: var(--color-brand);
    background: rgba(0, 180, 216, 0.05);
  }

  .phone-icon { font-size: 1.25rem; }
  .phone-number { font-weight: 700; color: var(--color-navy); font-size: 1rem; }
  .phone-label { font-size: 0.75rem; color: var(--color-muted); }

  /* WhatsApp card */
  .whatsapp-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: linear-gradient(135deg, #16a34a, #22C55E);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.5rem;
    box-shadow: 0 4px 16px rgba(34, 197, 94, 0.3);
    text-decoration: none;
    color: white;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .whatsapp-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(34, 197, 94, 0.4);
    color: white;
  }

  .whatsapp-icon {
    width: 52px;
    height: 52px;
    background: rgba(255,255,255,0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .whatsapp-label { font-size: 0.75rem; font-weight: 600; opacity: 0.8; }
  .whatsapp-number { font-size: 1.0625rem; font-weight: 800; }
  .whatsapp-status {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    opacity: 0.85;
    margin-top: 0.125rem;
  }

  .online-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #86efac;
    animation: blink 2s ease-in-out infinite;
  }

  /* Info items */
  .info-list { display: flex; flex-direction: column; gap: 0.875rem; }

  .info-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .info-icon { font-size: 1.125rem; flex-shrink: 0; margin-top: 0.125rem; }

  .info-item strong {
    display: block;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 0.125rem;
  }

  .info-item p {
    font-size: 0.8125rem;
    color: var(--color-muted);
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
    .contact-info-col {
      position: static;
      order: 2;
    }
  }
</style>
