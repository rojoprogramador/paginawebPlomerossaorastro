---
// src/pages/blog-plomeros-en-cali/index.astro

import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { buildTitle } from '../../lib/seo';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(d: Date) {
  return d.toLocaleDateString('es-CO', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Layout
  title={buildTitle('Blog Plomeros en Cali — Guías y Consejos de Plomería')}
  description="Blog de Plomeros SAOR: guías, consejos y artículos sobre detección de fugas, destape de cañerías, geófono, cámara térmica y plomería en Cali."
  canonical="/blog-plomeros-en-cali"
>
  <div style="padding-top:68px;" />

  <section style="background:var(--color-navy);padding:3.5rem 0;">
    <div class="container" style="text-align:center;">
      <span class="badge badge-brand" style="margin-bottom:1rem;display:inline-block;">📝 Blog</span>
      <h1 style="font-size:clamp(2rem,4vw,2.75rem);font-weight:800;color:white;line-height:1.15;margin-bottom:0.75rem;">
        Blog Plomeros en <span style="color:var(--color-brand);">Cali</span>
      </h1>
      <p style="font-size:1rem;color:rgba(255,255,255,0.7);max-width:560px;margin:0 auto;">
        Guías, consejos y soluciones a los problemas de plomería más comunes en Cali y Colombia.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {posts.length === 0 ? (
        <div style="text-align:center;padding:4rem;color:var(--color-muted);">
          <div style="font-size:3rem;margin-bottom:1rem;">📝</div>
          <p>Los artículos del blog se están preparando. ¡Vuelve pronto!</p>
        </div>
      ) : (
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1.5rem;">
          {posts.map((post, i) => (
            <article class="card" style="display:flex;flex-direction:column;">
              <div style="height:200px;background:linear-gradient(135deg,#e2edf7,#d0e8f4);border-radius:var(--radius-lg) var(--radius-lg) 0 0;overflow:hidden;position:relative;">
                <Image
                  src={post.data.image}
                  alt={post.data.imageAlt ?? post.data.title}
                  width={400}
                  height={200}
                  loading={i < 6 ? 'eager' : 'lazy'}
                  style="width:100%;height:100%;object-fit:cover;display:block;"
                />
              </div>
              <div style="padding:1.5rem;flex:1;display:flex;flex-direction:column;">
                <div style="font-size:0.75rem;color:var(--color-muted);margin-bottom:0.5rem;">
                  {formatDate(post.data.date)}
                </div>
                <h2 style="font-size:1rem;font-weight:700;color:var(--color-navy);line-height:1.35;margin-bottom:0.5rem;flex:1;">
                <a href={`/blog-plomeros-en-cali/${post.id.replace(/\.(md|mdx)$/, '')}`} style="text-decoration:none;color:inherit;">
                    {post.data.title}
                  </a>
                </h2>
                <p style="font-size:0.8125rem;color:var(--color-muted);line-height:1.6;margin-bottom:1rem;">
                  {post.data.description}
                </p>
                <a
                  href={`/blog-plomeros-en-cali/${post.id.replace(/\.(md|mdx)$/, '')}`}
                  style="font-size:0.875rem;font-weight:600;color:var(--color-brand);display:inline-flex;align-items:center;gap:0.25rem;"
                >
                  Leer artículo →
                </a>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>
